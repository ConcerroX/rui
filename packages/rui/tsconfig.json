{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": ["src/**/*", "src/**/*.vue"],
    "exclude": ["src/**/__tests__/*", "dist"],
    "compilerOptions": {
        "noUncheckedIndexedAccess": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationDir": "./dist/types",
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo"
    }
}
