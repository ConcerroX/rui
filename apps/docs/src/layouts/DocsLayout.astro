---
import BaseLayout from "./BaseLayout.astro"
import type { CollectionEntry } from "astro:content"
import { getDefaultSection, getModeUrl, getReadingMode, groupDocs } from "../lib/docs"

export interface Props {
    entry: CollectionEntry<"docs">
    locale: string
    allDocs: CollectionEntry<"docs">[]
}

const { entry, locale, allDocs } = Astro.props
const mode = getReadingMode(Astro.url)
const defaultSection = getDefaultSection(entry, mode)
const groupedDocs = groupDocs(allDocs, locale, mode)
const defaultSectionJson = JSON.stringify(defaultSection)
---

<BaseLayout title={entry.data.title} locale={locale} currentUrl={Astro.url} sectionLabel="Components">
    <style>
        .docs-shell {
            display: grid;
            gap: 1.5rem;
        }

        .docs-sidebar,
        .docs-content,
        .docs-outline {
            border: 1px solid #d0d0d0;
            padding: 1rem;
        }

        .docs-sidebar nav section + section {
            margin-top: 1rem;
        }

        .docs-sidebar ol,
        .docs-content ul,
        .docs-outline ul {
            margin: 0;
            padding-left: 1.25rem;
        }

        .docs-content header {
            margin-bottom: 1.5rem;
        }

        .docs-content h1 {
            margin-top: 0;
        }

        .docs-mode ul,
        .docs-tabs ul {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .docs-mode,
        .docs-tabs,
        .docs-links {
            margin-top: 1rem;
        }

        .docs-body section {
            display: none;
        }

        .docs-body section.is-active {
            display: block;
        }

        .docs-outline ul {
            list-style: none;
            padding-left: 0;
        }

        .docs-outline li + li {
            margin-top: 0.5rem;
        }

        @media (min-width: 900px) {
            .docs-shell {
                grid-template-columns: 16rem minmax(0, 1fr) 14rem;
                align-items: start;
            }

            .docs-sidebar,
            .docs-outline {
                position: sticky;
                top: 1rem;
            }
        }
    </style>

    <div class="docs-shell">
        <aside class="docs-sidebar">
            <nav aria-label="Components navigation">
                <h2>Components</h2>
                {groupedDocs.map(({ group, items }) => (
                    <section>
                        <h3>{group}</h3>
                        <ol>
                            {items.map((item) => (
                                <li>
                                    <a href={`/${locale}/docs/${item.data.routeSlug}`}>{item.data.title}</a>
                                </li>
                            ))}
                        </ol>
                    </section>
                ))}
            </nav>
        </aside>

        <article class="docs-content">
            <header>
                <h1>{entry.data.title}</h1>
                <p>Current reading mode: {mode}</p>
                <nav class="docs-mode" aria-label="Reading mode">
                    <ul>
                        <li><a href={getModeUrl(Astro.url, "design")} aria-current={mode === "design" ? "true" : undefined}>Design</a></li>
                        <li><a href={getModeUrl(Astro.url, "develop")} aria-current={mode === "develop" ? "true" : undefined}>Develop</a></li>
                    </ul>
                </nav>
                <nav class="docs-tabs" aria-label="Page sections">
                    <ul>
                        {entry.data.sections.map((section) => (
                            <li>
                                <a href={`?mode=${mode}&section=${section}`} aria-current={section === defaultSection ? "page" : undefined}>
                                    {section}
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
                <p class="docs-links">
                    <a href={entry.data.api}>View API</a>
                </p>
            </header>

            <div class="docs-body">
                <slot />
            </div>
        </article>

        <aside class="docs-outline">
            <nav aria-label="Current section outline">
                <h2>On this page</h2>
                <ul>
                    {entry.data.sections.map((section) => (
                        <li>
                            <a href={`#${section}`}>{section}</a>
                        </li>
                    ))}
                </ul>
            </nav>
        </aside>
    </div>

    <script define:vars={{ defaultSectionJson }}>
        const current = new URL(window.location.href)
        const section = current.searchParams.get("section") ?? JSON.parse(defaultSectionJson)
        const sections = document.querySelectorAll(".docs-body section")
        sections.forEach((node) => {
            node.classList.toggle("is-active", node.id === section)
        })
    </script>
</BaseLayout>
